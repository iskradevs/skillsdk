// kv

type KVGetArgs struct {
	Op  string `json:"op"`
	Key string `json:"key"`
}

type KVGetResult struct {
	Found bool            `json:"found"`
	Value json.RawMessage `json:"value,omitempty"`
}

type KVPutArgs struct {
	Op    string          `json:"op"`
	Key   string          `json:"key"`
	Value json.RawMessage `json:"value,omitempty"`
}

type KVDeleteArgs struct {
	Op  string `json:"op"`
	Key string `json:"key"`
}

func KVGet(key string) (json.RawMessage, bool, error) {
	args, err := json.Marshal(KVGetArgs{Op: "get", Key: key})
	if err != nil {
		return nil, false, err
	}
	res, env := capInvoke("kv", args)
	if env != nil {
		return nil, false, env
	}
	var out KVGetResult
	if err := json.Unmarshal(res, &out); err != nil {
		return nil, false, err
	}
	return out.Value, out.Found, nil
}

func KVPut(key string, value json.RawMessage) error {
	args, err := json.Marshal(KVPutArgs{Op: "put", Key: key, Value: value})
	if err != nil {
		return err
	}
	_, env := capInvoke("kv", args)
	if env != nil {
		return env
	}
	return nil
}

func KVDelete(key string) error {
	args, err := json.Marshal(KVDeleteArgs{Op: "delete", Key: key})
	if err != nil {
		return err
	}
	_, env := capInvoke("kv", args)
	if env != nil {
		return env
	}
	return nil
}
