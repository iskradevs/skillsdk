// secret

type secretGetArgs struct {
	Op   string `json:"op"`
	Slot string `json:"slot"`
}

type secretGetResult struct {
	Found bool   `json:"found"`
	Value string `json:"value,omitempty"`
}

// Secret fetches a declared secret slot. found=false means the slot is unset.
func Secret(slot string) (string, bool, error) {
	args, err := json.Marshal(secretGetArgs{Op: "get", Slot: slot})
	if err != nil {
		return "", false, err
	}
	res, env := capInvoke("secret", args)
	if env != nil {
		return "", false, env
	}
	var out secretGetResult
	if err := json.Unmarshal(res, &out); err != nil {
		return "", false, err
	}
	return out.Value, out.Found, nil
}
