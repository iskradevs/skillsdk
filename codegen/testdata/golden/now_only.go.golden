//go:build tinygo

// Code generated by "mcphub gen"; DO NOT EDIT.
//
// Guest SDK for an mcphub go-tinygo bundle: frozen ABI boilerplate plus typed
// wrappers over cap_call for the capabilities this bundle declares. The author
// writes only main() and handle().
//
// Wrappers cover the UNION of capabilities_required across the bundle's tools.
// A wrapper's presence does NOT grant a tool the capability: the host enforces
// capabilities_required per tool and rejects an undeclared call.
package main

import (
	"encoding/json"
	"unsafe"
)

//go:wasmexport mcphub_abi_version
func mcphubABIVersion() int32 { return 1 }

var pinned = map[uintptr][]byte{}

//go:wasmexport alloc
func alloc(size int32) int32 {
	if size <= 0 {
		return 0
	}
	buf := make([]byte, size)
	ptr := uintptr(unsafe.Pointer(&buf[0]))
	pinned[ptr] = buf
	return int32(ptr)
}

func writeBytes(b []byte) (uint32, uint32) {
	if len(b) == 0 {
		return 0, 0
	}
	ptr := alloc(int32(len(b)))
	dst := unsafe.Slice((*byte)(unsafe.Pointer(uintptr(uint32(ptr)))), len(b))
	copy(dst, b)
	return uint32(ptr), uint32(len(b))
}

// writeJSON packs a JSON envelope into handle's i64 return value. The author's
// handle() calls it to return its result envelope.
func writeJSON(b []byte) int64 {
	ptr, length := writeBytes(b)
	return (int64(ptr) << 32) | int64(length)
}

//go:wasmimport mcphub cap_call
func capCall(capPtr, capLen, argsPtr, argsLen uint32) uint64

// EnvError is the wire mirror of abi.EnvError (the guest does not import abi).
// Details is json.RawMessage because the guest only reads it.
type EnvError struct {
	Code    string          `json:"code"`
	Message string          `json:"message"`
	Details json.RawMessage `json:"details,omitempty"`
}

func (e *EnvError) Error() string { return e.Code + ": " + e.Message }

type capResponse struct {
	Result json.RawMessage `json:"result,omitempty"`
	Error  *EnvError       `json:"error,omitempty"`
}

func capInvoke(capName string, args []byte) (json.RawMessage, *EnvError) {
	cp, cl := writeBytes([]byte(capName))
	ap, al := writeBytes(args)
	packed := capCall(cp, cl, ap, al)
	ptr := uint32(packed >> 32)
	n := uint32(packed)
	if n == 0 {
		return nil, &EnvError{Code: "bad_cap_response", Message: "empty cap response"}
	}
	raw := unsafe.Slice((*byte)(unsafe.Pointer(uintptr(ptr))), n)
	var r capResponse
	if err := json.Unmarshal(raw, &r); err != nil {
		return nil, &EnvError{Code: "bad_cap_response", Message: "cannot parse cap response"}
	}
	if r.Error != nil {
		return nil, r.Error
	}
	return r.Result, nil
}

// now

type NowResult struct {
	UnixNano int64 `json:"unix_nano"`
}

func Now() (int64, error) {
	res, env := capInvoke("now", []byte(`{}`))
	if env != nil {
		return 0, env
	}
	var out NowResult
	if err := json.Unmarshal(res, &out); err != nil {
		return 0, err
	}
	return out.UnixNano, nil
}
